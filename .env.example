# ─── API ─────────────────────────────────────────────────────────────────────
# API Gateway URL — Vite dev proxy hedefi (production'da nginx kullanılır, bu değer yalnızca lokal içindir)
VITE_GATEWAY_URL=http://localhost:3002

# Backend REST prefix
VITE_API_PREFIX=/api/v1

# ─── WebSocket ───────────────────────────────────────────────────────────────
# Socket.IO sunucusunun adresi
# socketClient.ts → io(WS_URL, ...) — AuthContext.tsx üzerinden bağlanılır
VITE_WS_URL=http://localhost:3001
