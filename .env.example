# FlowTera Frontend — Environment Variables
# Copy this file to .env and fill in your values.

#─ API Gateway 
# URL of the backend API gateway (used by Vite dev server proxy)
# Production: set to your deployed gateway URL
VITE_GATEWAY_URL=http://localhost:3002

# REST API prefix — must match backend route prefix
VITE_API_PREFIX=/api/v1

# WebSocket 
# Node Core Service WebSocket URL (direct connection, not proxied)
# Must match WS_URL in node-core-service/.env
# Production: use wss:// for HTTPS deployments
VITE_WS_URL=http://localhost:3001

# Demo Account
# Credentials for the public demo account shown on the landing page
# Leave VITE_DEMO_PASSWORD blank if you don't want auto-fill on the login page
VITE_DEMO_EMAIL=demo@flowtera.app
VITE_DEMO_PASSWORD=

# Legacy / Unused
# These keys are retained for compatibility but not actively used in the codebase
# VITE_USE_MOCK=false
# VITE_API_BASE_URL=/data
