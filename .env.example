# API Gateway URL (Vite dev server proxy target)
VITE_GATEWAY_URL=http://localhost:3002

# Set to true to use local mock JSON files instead of the backend
VITE_USE_MOCK=false

# Mock JSON base path (public/data folder)
VITE_API_BASE_URL=/data

# Backend REST API prefix
VITE_API_PREFIX=/api/v1

# Socket.IO server URL
VITE_WS_URL=http://localhost:3001

# Demo account credentials (shown on landing page "Try Demo" button)
VITE_DEMO_EMAIL=demo@flowtera.app
VITE_DEMO_PASSWORD=
