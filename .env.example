# ─── API ─────────────────────────────────────────────────────────────────────
# Mock mod aktifken /data/*.json dosyaları kullanılır
# Backend hazır olduğunda false yap
VITE_USE_MOCK=true

# Mock JSON'ların servis edildiği klasör (public/data)
VITE_API_BASE_URL=/data

# Backend REST prefix — IS_MOCK=false olunca devreye girer
VITE_API_PREFIX=/api/v1

# ─── WebSocket ───────────────────────────────────────────────────────────────
# Socket.IO sunucusunun adresi
# socketClient.ts → io(WS_URL, ...) — AuthContext.tsx üzerinden bağlanılır
VITE_WS_URL=http://localhost:3001
